# DMIMS environment configuration.
# These are SAFE LOCAL DEFAULTS. For production see the notes marked
# "PRODUCTION:" below and DEPLOYMENT_GUIDE.md. Never commit a real .env.
APP_NAME=DMIMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# PRODUCTION: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local default: SQLite (run `touch database/database.sqlite`).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# PRODUCTION: MariaDB 11 (MySQL-compatible; use DB_CONNECTION=mysql):
#   DB_CONNECTION=mysql
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
#   DB_DATABASE=dmims_production
#   DB_USERNAME=dmims_user
#   DB_PASSWORD=your_secure_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
# Cookie is only sent over HTTPS when true. Keep FALSE for local HTTP dev.
# PRODUCTION: set true ONLY if the app is served over HTTPS on every path.
# The reference Cloudflare Tunnel deployment is also reached over plain HTTP
# on localhost/LAN, so it intentionally keeps this false — see
# DEPLOYMENT_GUIDE.md. A forced secure cookie would break login on HTTP.
SESSION_SECURE_COOKIE=false

# Comma-separated proxy IPs, or * to trust all. Leave empty for local dev.
# PRODUCTION (behind Cloudflare Tunnel): TRUSTED_PROXIES=*
TRUSTED_PROXIES=

# Sanctum API token lifetime in minutes. Default 525600 = 365 days. Set to a
# blank value to disable expiration and let tokens live forever.
SANCTUM_TOKEN_EXPIRATION=525600

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local default: log (emails written to storage/logs, not delivered).
# PRODUCTION: a real SMTP mailer is REQUIRED — password-reset emails are only
# delivered when MAIL_MAILER=smtp with valid credentials. See DEPLOYMENT_GUIDE.md.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_TO_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
